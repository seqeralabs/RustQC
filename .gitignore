# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Test output directories (generated by cargo test / manual runs)
tests/output*/

# Large benchmark input files (download separately, see benchmark/README.md)
benchmark/input/**/*.bam
benchmark/input/**/*.bam.bai
benchmark/input/**/*.gtf
benchmark/input/**/*.gtf.gz
benchmark/input/**/*.bed
benchmark/input/**/*.bed.gz

# Large RSeQC reference outputs (too big for git)
*.inner_distance.txt
*.junction.bed
*.junction.xls
benchmark/rseqc/**/junction_annotation.junction.Interact.bed

# Large TIN reference outputs
benchmark/rseqc/**/tin.xls

# Session files
session-*.md

# macOS metadata
.DS_Store
**/.DS_Store

# Python cache
.ruff_cache/
*.pyc
__pycache__/

# IDE config
.vscode/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
